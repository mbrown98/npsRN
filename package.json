{
  "name": "Parkport",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "android": "node ./node_modules/react-native/cli.js run-android",
    "ios": "node ./node_modules/react-native/cli.js run-ios",
    "lint": "eslint .",
    "metro:stop": "lsof -ti:8081 | xargs kill 2>/dev/null || true",
    "start": "node ./node_modules/react-native/cli.js start --no-interactive",
    "start:8082": "node ./node_modules/react-native/cli.js start --no-interactive --port 8082",
    "start:ci": "CI=true node ./node_modules/react-native/cli.js start --no-interactive",
    "start:fresh": "npm run metro:stop && node ./node_modules/react-native/cli.js start --no-interactive --reset-cache",
    "test": "jest"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/auth": "^21.14.0",
    "@react-native-firebase/firestore": "^21.14.0",
    "@react-native-google-signin/google-signin": "^13.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "prop-types": "^15.8.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-inappbrowser-reborn": "^3.7.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "^1.20.1",
    "react-native-open-maps": "^0.4.3",
    "react-native-safe-area-context": "^4.14.1",
    "react-native-screens": "4.4.0",
    "react-native-splash-screen": "^3.3.0",
    "react-native-svg": "15.12.1",
    "react-native-swiper": "^1.6.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@react-native/typescript-config": "0.76.9",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
